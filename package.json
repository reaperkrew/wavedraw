{
  "name": "wavedraw",
  "version": "2.0.0",
  "description": "Dependency-light WAV parsing and waveform rendering for Node.js.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require(\\\"node:fs\\\").rmSync(\\\"dist\\\",{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "wave",
    "wav",
    "draw",
    "plot",
    "graph",
    "image",
    "render",
    "rms",
    "svg",
    "audio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/reaperkrew/wavedraw.git"
  },
  "author": "reaperkrew",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
